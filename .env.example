# FaizxAi Bot — Environment Configuration
# Copy this file to .env and fill in your values

# ── Discord ───────────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here
GUILD_ID=your_discord_server_id_here

# ── Bot Settings ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
CONFIG_PATH=src/config/server.yml
PRIVILEGED_INTENTS=true

# ── AI Provider (choose one: bluesminds / openai / gemini) ───────────────────
AI_PROVIDER=bluesminds

# Bluesminds (default)
BLUESMINDS_API_KEY=your_bluesminds_api_key_here
BLUESMINDS_BASE=https://api.bluesminds.com/v1
BLUESMINDS_MODEL=gpt-5.5

# OpenAI (optional)
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini (optional)
GEMINI_API_KEY=your_gemini_api_key_here

# CastAI (optional)
CASTAI_API_KEY=your_castai_api_key_here
